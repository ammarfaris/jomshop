# Appwrite Configuration (for server-side metadata generation)
APPWRITE_API_KEY=your_api_key_here

# Base URL for the application (used in metadata generation)
NEXT_PUBLIC_BASE_URL=https://jomcontest.com

# Maintenance mode switch (server-side only)
# true  = all pages rewrite to /maintenance
# false = normal behavior
MAINTENANCE_MODE=false

# --- Supabase migration (Phase 0 spike) ---
# Backend selector: 'appwrite' (default) or 'supabase'
NEXT_PUBLIC_BACKEND=appwrite
# From Supabase project settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=
# New publishable key (sb_publishable_…). Legacy NEXT_PUBLIC_SUPABASE_ANON_KEY also accepted.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
