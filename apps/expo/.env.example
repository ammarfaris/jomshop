# --- Supabase migration (Phase 0 spike) ---
# Backend selector: 'appwrite' (default) or 'supabase'
EXPO_PUBLIC_BACKEND=appwrite
# From Supabase project settings > API Keys
EXPO_PUBLIC_SUPABASE_URL=
# New publishable key (sb_publishable_…). Legacy EXPO_PUBLIC_SUPABASE_ANON_KEY also accepted.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
